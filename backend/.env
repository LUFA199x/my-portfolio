# ─────────────────────────────────────
# SERVER
# ─────────────────────────────────────
NODE_ENV=development
PORT=4000
API_VERSION=v1

# ─────────────────────────────────────
# DATABASE (PostgreSQL)
# ─────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/arhday_db?schema=public"

# ─────────────────────────────────────
# REDIS (Caching & Rate Limiting)
# ─────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_TTL=3600

# ─────────────────────────────────────
# JWT TOKENS
# ─────────────────────────────────────
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────
# CORS
# ─────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ─────────────────────────────────────
# CLOUDINARY (Image Storage)
# ─────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_FOLDER=arhday

# ─────────────────────────────────────
# EMAIL (SendGrid)
# ─────────────────────────────────────
SENDGRID_API_KEY=SG.your_sendgrid_api_key
EMAIL_FROM=noreply@arhday.com
EMAIL_FROM_NAME=ARHDAY Photography
ADMIN_EMAIL=bookarhday@gmail.com

# ─────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_CONTACT_MAX=5

# ─────────────────────────────────────
# FRONTEND
# ─────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─────────────────────────────────────
# LOGGING
# ─────────────────────────────────────
LOG_LEVEL=debug
LOG_DIR=logs
